{
  "name": "uefn-code-review",
  "displayName": "UEFN Code Review",
  "description": "Multi-snippet code reviews to Slack with auto-Git diff, threaded AI feedback, and Gemini pre-review",
  "version": "0.2.9",
  "publisher": "uefn-team",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "activationEvents": [
    "onCommand:uefnCodeReview.addSnippet",
    "onCommand:uefnCodeReview.sendSession",
    "onCommand:uefnCodeReview.discardSession",
    "onCommand:uefnCodeReview.showSession",
    "onCommand:uefnCodeReview.configure",
    "onCommand:uefnCodeReview.listModels",
    "onCommand:uefnCodeReview.diagnoseGit",
    "onCommand:uefnCodeReview.diagnoseStyleGuide",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "uefnCodeReview.addSnippet",
        "title": "Add Snippet to Review",
        "category": "Code Review"
      },
      {
        "command": "uefnCodeReview.sendSession",
        "title": "Send Review",
        "category": "Code Review"
      },
      {
        "command": "uefnCodeReview.discardSession",
        "title": "Discard Pending Review",
        "category": "Code Review"
      },
      {
        "command": "uefnCodeReview.showSession",
        "title": "Show Pending Review",
        "category": "Code Review"
      },
      {
        "command": "uefnCodeReview.configure",
        "title": "Configure Credentials",
        "category": "Code Review"
      },
      {
        "command": "uefnCodeReview.listModels",
        "title": "List Available Gemini Models",
        "category": "Code Review"
      },
      {
        "command": "uefnCodeReview.diagnoseGit",
        "title": "Diagnose Git",
        "category": "Code Review"
      },
      {
        "command": "uefnCodeReview.diagnoseStyleGuide",
        "title": "Diagnose Style Guide",
        "category": "Code Review"
      }
    ],
    "keybindings": [
      {
        "command": "uefnCodeReview.addSnippet",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorHasSelection"
      },
      {
        "command": "uefnCodeReview.sendSession",
        "key": "ctrl+shift+alt+r",
        "mac": "cmd+shift+alt+r"
      }
    ],
    "configuration": {
      "title": "UEFN Code Review",
      "properties": {
        "uefnCodeReview.author": {
          "type": "string",
          "default": ""
        },
        "uefnCodeReview.enableAiPreReview": {
          "type": "boolean",
          "default": true
        },
        "uefnCodeReview.styleGuidePath": {
          "type": "string",
          "default": ".verse-style.md"
        },
        "uefnCodeReview.globalStyleGuidePath": {
          "type": "string",
          "default": "",
          "description": "ABSOLUTE path to a fallback style guide. Used when the workspace doesn't have one."
        },
        "uefnCodeReview.geminiModel": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "enum": [
            "gemini-2.5-flash",
            "gemini-2.5-flash-lite",
            "gemini-2.0-flash",
            "gemini-2.0-flash-lite-001",
            "gemini-1.5-flash",
            "gemini-flash-latest"
          ]
        },
        "uefnCodeReview.aiTemperature": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1,
          "description": "AI generation temperature. 0.0 = deterministic (same code → same review). 0.2+ = creative but inconsistent. Keep at 0 for code review reliability."
        },
        "uefnCodeReview.diffStyle": {
          "type": "string",
          "default": "unified",
          "enum": [
            "unified",
            "side-by-side"
          ]
        },
        "uefnCodeReview.useGitForOldCode": {
          "type": "boolean",
          "default": true
        },
        "uefnCodeReview.diffContextLines": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 10
        },
        "uefnCodeReview.jiraBaseUrl": {
          "type": "string",
          "default": "https://teravisiongames.atlassian.net/browse/"
        },
        "uefnCodeReview.projects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Programming",
            "DnD"
          ]
        },
        "uefnCodeReview.reviewTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Bug Fixed",
            "Bug",
            "New Feature",
            "Refactor",
            "Hotfix",
            "Code Review",
            "Question"
          ]
        },
        "uefnCodeReview.testedInOptions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "UEFN Session",
            "UEFN Editor",
            "Local",
            "Manual"
          ]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
